---
import type { CollectionEntry } from "astro:content";
import { Root } from "../layouts";
import {
  Draft,
  HorizontalSeperator,
  Method,
  TimesServes,
  ToolsIngredients,
} from "../components";

type Props = CollectionEntry<"recipes">["data"];

const {
  name,
  image,
  description,
  creativeWorkStatus,
  prepTime,
  cookTime,
  totalTime,
  recipeYield,
  recipeIngredient,
  tool,
  recipeInstructions,
} = Astro.props;
---

<Root title={name} description={description}>
  <article class="w-full max-w-6xl mx-auto px-4 py-10 flex flex-col gap-8">
    <div class="flex flex-col items-center gap-4">
      {
        image != null && image[0] != null && (
          <img
            width="300"
            height="300"
            src={image[0]}
            alt={name}
            class="w-4/5 sm:w-1/2 lg:w-1/3 rounded-2xl shadow-xl shadow-black/40"
          />
        )
      }
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-display font-medium text-center">
        {name}
      </h1>
    </div>

    <div class="flex flex-col gap-4 bg-surface-1 rounded-xl p-6 max-w-2xl w-full mx-auto">
      <Draft creativeWorkStatus={creativeWorkStatus} />
      <p class="text-center text-white/80">{description}</p>
      <HorizontalSeperator variant="primary" />
      <TimesServes
        prepTime={prepTime}
        cookTime={cookTime}
        totalTime={totalTime}
        recipeYield={recipeYield}
      />
    </div>

    <div class="flex flex-col lg:flex-row gap-8 w-full">
      <div class="lg:w-72 lg:shrink-0">
        <ToolsIngredients tool={tool} recipeIngredient={recipeIngredient} />
      </div>
      <!-- horizontal rule on mobile only -->
      <hr class="lg:hidden border-white/20" />
      <Method recipeInstructions={recipeInstructions} />
    </div>
  </article>
</Root>
