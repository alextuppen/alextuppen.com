---
import type { CollectionEntry } from "astro:content";
import { Root } from "../layouts";
import {
  Draft,
  Method,
  TimesServes,
  ToolsIngredients,
} from "../components";

type Props = CollectionEntry<"recipes">["data"];

const {
  name,
  image,
  description,
  creativeWorkStatus,
  prepTime,
  cookTime,
  totalTime,
  recipeYield,
  recipeIngredient,
  tool,
  recipeInstructions,
} = Astro.props;
---

<Root title={name} description={description}>
  <article class="w-full max-w-4xl mx-auto px-4 py-10 flex flex-col gap-6">
    {
      image != null && image[0] != null && (
        <img
          width="900"
          height="500"
          src={image[0]}
          alt={name}
          class="w-full rounded-2xl shadow-xl shadow-black/40 object-cover h-64 sm:h-[21.25rem] lg:h-[26.75rem] mx-auto block"
        />
      )
    }

    <div class="flex flex-col gap-3">
      <Draft creativeWorkStatus={creativeWorkStatus} />
      <h1 class="text-3xl sm:text-4xl lg:text-6xl font-display font-medium">
        {name}
      </h1>
      <p class="text-white/80 leading-relaxed">{description}</p>
    </div>

    <div class="bg-surface-1 rounded-lg px-4 py-5">
      <TimesServes
        prepTime={prepTime}
        cookTime={cookTime}
        totalTime={totalTime}
        recipeYield={recipeYield}
      />
    </div>

    <div class="flex flex-col lg:flex-row gap-8 w-full">
      <div class="lg:w-72 lg:shrink-0">
        <ToolsIngredients tool={tool} recipeIngredient={recipeIngredient} />
      </div>
      <!-- horizontal rule on mobile only -->
      <hr class="lg:hidden border-white/20" />
      <Method recipeInstructions={recipeInstructions} />
    </div>
  </article>
</Root>
