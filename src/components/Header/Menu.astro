---
import { internalLinks, externalLinks } from "./Header.astro";

const pathname = Astro.url.pathname;
const isActive = (link: string) =>
  pathname === link || pathname.startsWith(link + "/");
---

<button
  id="menuBurger"
  aria-label="Toggle navigation menu"
  class="relative w-8 h-8 flex flex-col justify-center items-center gap-1.5 p-1 rounded focus-visible:outline-2 focus-visible:outline-primary"
>
  <span id="menuBurgerBar1" class="block w-6 h-[3px] bg-white origin-center transition-all duration-300"></span>
  <span id="menuBurgerBar2" class="block w-6 h-[3px] bg-primary origin-center transition-all duration-300"></span>
  <span id="menuBurgerBar3" class="block w-6 h-[3px] bg-white origin-center transition-all duration-300"></span>
</button>
<div
  id="menu"
  class="absolute right-0 top-full mt-2 bg-surface-9 rounded-lg border border-white/10 shadow-xl min-w-36 flex flex-col py-2 origin-top transition-all duration-200 opacity-0 scale-y-0 pointer-events-none"
  aria-hidden="true"
>
  {
    internalLinks.map((item) => {
      const Icon = item.Icon;
      const active = isActive(item.link);
      return (
        <a
          href={item.link}
          class={`px-4 py-3 text-sm w-full flex items-center gap-2.5 active:bg-white/10 ${
            active
              ? "text-primary font-semibold pointer-events-none"
              : "text-white/80 hover:text-white hover:bg-white/5"
          }`}
        >
          <Icon className="w-4 h-4 shrink-0" />
          {item.text}
        </a>
      );
    })
  }
  <hr class="border-white/10 mx-3 my-1" />
  {
    externalLinks.map((item) => {
      const Icon = item.Icon;
      return (
        <a
          href={item.link}
          target="_blank"
          rel="noreferrer noopener"
          class="px-4 py-3 text-sm text-white/80 hover:text-white hover:bg-white/5 active:bg-white/10 w-full flex items-center gap-2.5"
        >
          <Icon className="w-4 h-4 shrink-0" />
          {item.text}
        </a>
      );
    })
  }
</div>

<script>
  let open = false;
  const button = document.getElementById("menuBurger");
  const menu = document.getElementById("menu");
  const bar1 = document.getElementById("menuBurgerBar1");
  const bar2 = document.getElementById("menuBurgerBar2");
  const bar3 = document.getElementById("menuBurgerBar3");

  if (button && menu && bar1 && bar2 && bar3) {
    const setOpen = (value: boolean) => {
      open = value;

      // Animate burger bars into X (translateY = bar height/2 + gap = 1.5px + 6px + 1.5px = 9px)
      if (value) {
        bar1.style.transform = "translateY(9px) rotate(45deg)";
        bar2.style.opacity = "0";
        bar3.style.transform = "translateY(-9px) rotate(-45deg)";
      } else {
        bar1.style.transform = "";
        bar2.style.opacity = "";
        bar3.style.transform = "";
      }

      // Toggle dropdown via classes (Tailwind v4 uses the CSS `scale` property,
      // not `transform`, so inline style overrides don't work for scale-y-*)
      menu.classList.toggle("opacity-0", !value);
      menu.classList.toggle("scale-y-0", !value);
      menu.classList.toggle("pointer-events-none", !value);
      menu.setAttribute("aria-hidden", value ? "false" : "true");
    };

    button.addEventListener("click", () => setOpen(!open));

    document.addEventListener("click", (e) => {
      if (open && !button.contains(e.target as Node) && !menu.contains(e.target as Node)) {
        setOpen(false);
      }
    });
  }
</script>
