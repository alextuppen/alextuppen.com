---
import { internalLinks, externalLinks } from "./Header/Header.astro";

const today = new Date();
---

<footer class="border-t border-white/10">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Main footer content -->
    <div class="flex flex-col md:flex-row items-center md:justify-center gap-8">
      <!-- Logo -->
      <a href="/">
        <img src="/logo/white.svg" alt="Alex Tuppen logo" class="w-12 opacity-70 hover:opacity-100 transition-opacity" />
      </a>

      <!-- Link columns -->
      <div class="flex flex-row gap-16">
        <!-- Nav links -->
        <div class="flex flex-col gap-2">
          <p class="text-xs font-semibold text-white/30 uppercase tracking-wider mb-1">Pages</p>
          {internalLinks.map(({ link, text }) => (
            <a href={link} class="text-sm text-white/60 hover:text-white transition-colors">{text}</a>
          ))}
        </div>

        <!-- Social links -->
        <div class="flex flex-col gap-2">
          <p class="text-xs font-semibold text-white/30 uppercase tracking-wider mb-1">Social</p>
          {externalLinks.map(({ link, text }) => (
            <a href={link} target="_blank" rel="noopener noreferrer" class="text-sm text-white/60 hover:text-white transition-colors">{text}</a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-center gap-6 text-xs text-white/30">
      <p>Copyright &copy; {today.getFullYear()} Alex Tuppen</p>
      <a
        href="https://www.gnu.org/licenses/gpl-3.0.en.html"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-white/60 transition-colors"
      >
        Open source — GNU GPL v3
      </a>
    </div>
  </div>
</footer>
