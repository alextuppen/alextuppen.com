---
import type { expEduDetailsSchema } from "../../../schemas/expEduDetailsSchema";
import dayjs from "dayjs";

const MONTH_FORMAT = "MMMM YYYY";
const YEAR_FORMAT = "YYYY";

interface Props {
  details: ReturnType<(typeof expEduDetailsSchema)["parse"]>;
  month: boolean;
}

const {
  details: { title, organisation, startDate, endDate, location, roleType },
  month,
} = Astro.props;

const parsedStartDate = dayjs(startDate);
const parsedEndDate = dayjs(endDate);

const formattedStartDate = month
  ? parsedStartDate.format(MONTH_FORMAT)
  : parsedStartDate.format(YEAR_FORMAT);

const formattedEndDate =
  endDate == null
    ? "Present"
    : month
      ? parsedEndDate.format(MONTH_FORMAT)
      : parsedEndDate.format(YEAR_FORMAT);
---

<div class="p-6 flex flex-col gap-1">
  <h3 class="text-lg font-semibold text-white">{title}</h3>
  <span class="text-white/60 text-sm font-medium">{organisation}</span>
  <div class="flex flex-wrap gap-x-3 gap-y-1 mt-1 text-xs text-white/40">
    <span>{formattedStartDate} — {formattedEndDate}</span>
    <span>&middot;</span>
    <span>{location}</span>
    <span>&middot;</span>
    <span>{roleType}</span>
  </div>
</div>
