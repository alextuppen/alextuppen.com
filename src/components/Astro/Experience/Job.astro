---
import type { CollectionEntry } from "astro:content";
import ExpEduDetails from "./ExpEduDetails.astro";
import { Technologies } from "./Technologies";

interface Props {
  data: CollectionEntry<"experiences">["data"];
}

const {
  data: { description, details, technologies },
} = Astro.props;
---

<div class="w-full bg-surface-1 rounded-xl overflow-hidden text-left max-w-2xl">
  <ExpEduDetails details={details} month={true} />
  {
    description && description.length > 0 ? (
      <p class="px-6 pb-6 text-sm text-white/70 whitespace-pre-line leading-relaxed">
        {description.join("")}
      </p>
    ) : (
      <p class="px-6 pb-6 text-sm text-white/40 italic">Description coming soon!</p>
    )
  }
  {technologies && <Technologies technologies={technologies} />}
</div>
