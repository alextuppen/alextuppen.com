---
import { URL_LINKEDIN, URL_INSTAGRAM, URL_GITHUB } from "../../../consts";
import Button from "../Button.astro";
import Menu from "./Menu.astro";

export const internalLinks = [
  { link: "/recipes", text: "Recipes" },
  { link: "/blog", text: "Blog" },
  { link: "/experience", text: "Experience" },
];

export const externalLinks = [
  { link: URL_LINKEDIN, text: "LinkedIn" },
  { link: URL_INSTAGRAM, text: "Instagram" },
  { link: URL_GITHUB, text: "Github" },
];
---

<header class="sticky top-0 z-50 bg-surface-6/95 backdrop-blur-sm border-b border-white/10">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <Button href="/" variant="text" className="min-w-0 flex items-center gap-3 !no-underline group">
      <img
        src="/logo/white.svg"
        alt="Alex Tuppen logo"
        class="h-8 w-auto transition-opacity group-hover:opacity-80"
      />
      <span class="font-display font-medium text-xl sm:text-2xl text-white truncate">
        Alex Tuppen
      </span>
    </Button>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {
        internalLinks.map(({ link, text }, i) => (
          <>
            <Button href={link} variant="text" className="px-3 py-1 text-sm font-medium text-white/80 hover:text-white">
              {text}
            </Button>
            {i < internalLinks.length - 1 && (
              <span class="text-white/20">|</span>
            )}
          </>
        ))
      }
      <span class="text-primary mx-2">|</span>
      {
        externalLinks.map(({ link, text }, i) => (
          <>
            <Button href={link} variant="text" external className="px-3 py-1 text-sm font-medium text-white/80 hover:text-white">
              {text}
            </Button>
            {i < externalLinks.length - 1 && (
              <span class="text-white/20">|</span>
            )}
          </>
        ))
      }
    </nav>

    <!-- Mobile burger -->
    <div class="relative shrink-0 md:hidden">
      <Menu />
    </div>
  </div>
</header>
