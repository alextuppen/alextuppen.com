---
import SearchInput from "./SearchInput.astro";

export interface ListItem {
  href: string;
  title: string;
  src: string | undefined;
  alt: string | undefined;
  date?: string | undefined;
  description: string;
  keywords?: string[] | undefined;
  isFeatured?: boolean;
}

interface Props {
  list: ListItem[];
  showSearch?: boolean;
  noun?: string;
  featuredLabel?: string;
  featuredCount?: number;
}

const { list, showSearch = true, noun = "post", featuredLabel = "Latest", featuredCount } = Astro.props;
---

<div class="w-full flex flex-col gap-6">
  {showSearch && (
    <SearchInput
      id="blog-recipe-search"
      placeholder={`Search ${list.length} ${list.length === 1 ? noun : noun + "s"}...`}
    />
  )}
  <p id="blog-recipe-count" class="hidden text-sm text-white/40"></p>
  <script
    is:inline
    type="application/json"
    id="blog-recipe-list-data"
    set:html={JSON.stringify(list)}
  />
  <ol id="blog-recipe-list" class="w-full flex flex-col gap-6">
    {
      list.map((item, index) => (
        <>
          {featuredCount != null && index === featuredCount && (
            <li aria-hidden="true"><hr class="border-white/10" /></li>
          )}
          <li class="group" data-index={index}>
          <a
            href={item.href}
            class={`flex flex-col md:flex-row bg-surface-1 rounded-xl overflow-hidden hover:bg-surface-2 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/40 transition-[background-color,transform,box-shadow] duration-200 shadow-lg shadow-black/20 ${item.isFeatured ? "border-r-4 border-primary" : ""}`}
          >
            {item.src != null && item.alt != null ? (
              <img
                class="w-full md:w-48 h-48 object-cover shrink-0"
                width={300}
                height={300}
                src={item.src}
                alt={item.alt}
              />
            ) : (
              <div class="w-full md:w-48 h-48 shrink-0 flex items-center justify-center bg-surface-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-16 h-16 text-white/20">
                  <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
                  <path d="M1.5 2A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2zm13 1a.5.5 0 0 1 .5.5v6l-3.775-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12v.54L1 12.5v-9a.5.5 0 0 1 .5-.5z" />
                </svg>
              </div>
            )}
            <div class="p-5 flex flex-col gap-1.5 text-left">
              <div class="flex items-start justify-between gap-3">
                <h2 class="text-xl font-semibold group-hover:underline group-hover:decoration-primary">
                  {item.title}
                </h2>
                {item.isFeatured && <span class="text-xs text-primary bg-primary/10 rounded-full px-2.5 py-0.5 font-medium shrink-0 mt-0.5">{featuredLabel}</span>}
              </div>
              {item.date && <p class="text-xs text-primary/80 font-medium">{item.date}</p>}
              <p class="text-white/60 text-sm leading-relaxed">{item.description}</p>
            </div>
          </a>
        </li>
        </>
      ))
    }
  </ol>
  <p id="blog-recipe-no-results" class="text-white/50 text-center py-8 hidden">
    No results found
  </p>
</div>

<script>
  import Fuse from "fuse.js";

  const dataEl = document.getElementById("blog-recipe-list-data");
  const searchEl = document.getElementById("blog-recipe-search") as HTMLInputElement | null;
  const listEl = document.getElementById("blog-recipe-list");
  const noResultsEl = document.getElementById("blog-recipe-no-results");
  const countEl = document.getElementById("blog-recipe-count");

  if (dataEl && searchEl && listEl) {
    const list = JSON.parse(dataEl.textContent ?? "[]");
    const fuse = new Fuse(list, {
      keys: ["title", "description", "keywords"],
      includeScore: true,
      threshold: 0.3,
    });

    const allItems = Array.from(listEl.querySelectorAll<HTMLLIElement>("li[data-index]"));

    searchEl.addEventListener("input", () => {
      const value = searchEl.value.trim();

      if (!value) {
        allItems.forEach((item) => {
          item.style.display = "";
          item.style.order = "";
        });
        if (noResultsEl) noResultsEl.classList.add("hidden");
        if (countEl) countEl.classList.add("hidden");
        return;
      }

      const results = fuse.search(value);
      const resultIndices = new Map(results.map((r, i) => [r.refIndex, i]));

      let visibleCount = 0;
      allItems.forEach((item) => {
        const idx = parseInt(item.dataset["index"] ?? "-1");
        if (resultIndices.has(idx)) {
          item.style.display = "";
          item.style.order = String(resultIndices.get(idx));
          visibleCount++;
        } else {
          item.style.display = "none";
        }
      });

      if (noResultsEl) noResultsEl.classList.toggle("hidden", visibleCount > 0);
      if (countEl) {
        countEl.textContent = `${visibleCount} ${visibleCount === 1 ? "result" : "results"}`;
        countEl.classList.toggle("hidden", visibleCount === 0);
      }
    });
  }
</script>
