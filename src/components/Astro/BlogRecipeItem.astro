---
export interface ListItem {
  href: string;
  title: string;
  src: string | undefined;
  alt: string | undefined;
  subtitle?: string | undefined;
  description: string;
  keywords?: string[] | undefined;
}

interface Props {
  item: ListItem;
}

const { item: { href, title, src, alt, subtitle, description } } = Astro.props;
---

<li class="w-full">
  <a
    href={href}
    class="group flex flex-col md:flex-row bg-surface-1 rounded-xl overflow-hidden hover:bg-surface-2 transition-colors duration-200 shadow-lg shadow-black/20"
  >
    {
      src != null && alt != null ? (
        <img
          class="w-full md:w-48 h-48 object-cover shrink-0"
          width={300}
          height={300}
          src={src}
          alt={alt}
        />
      ) : (
        <div class="w-full md:w-48 h-48 shrink-0 flex items-center justify-center bg-surface-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            fill="currentColor"
            class="w-16 h-16 text-white/20"
          >
            <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
            <path d="M1.5 2A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2zm13 1a.5.5 0 0 1 .5.5v6l-3.775-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12v.54L1 12.5v-9a.5.5 0 0 1 .5-.5z" />
          </svg>
        </div>
      )
    }
    <div class="p-5 flex flex-col gap-1 text-left">
      <h2 class="text-lg font-semibold group-hover:underline group-hover:decoration-primary">
        {title}
      </h2>
      {subtitle && <p class="text-white/80 text-base font-medium">{subtitle}</p>}
      <p class="text-white/50 text-sm leading-relaxed mt-0.5">{description}</p>
    </div>
  </a>
</li>
