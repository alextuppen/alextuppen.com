---
interface Props {
  id?: string;
  variant?: "primary" | "text" | "subtle";
}

const { id, variant = "primary" } = Astro.props;
---

<hr
  id={id}
  class:list={[
    "border-0 border-b mx-8",
    variant === "primary"
      ? "border-primary"
      : variant === "subtle"
        ? "border-white/10"
        : "border-white",
  ]}
/>
