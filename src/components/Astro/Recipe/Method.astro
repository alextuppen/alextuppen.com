---
import { LightBulb } from "../../../svg";
import type { CollectionEntry } from "astro:content";

interface Props {
  recipeInstructions: CollectionEntry<"recipes">["data"]["recipeInstructions"];
}

const { recipeInstructions } = Astro.props;
---

<div class="flex-1 px-4 lg:px-0 lg:pt-6">
  <h2 class="text-xs font-semibold text-white/50 uppercase tracking-wider mb-6">Method</h2>
  <ol class="flex flex-col gap-8 list-none p-0 text-left counter-reset-[method]">
    {
      recipeInstructions.map((instruction, idx) => (
        <li class="flex flex-col gap-3">
          <h4 class="flex items-baseline gap-2 font-semibold text-white">
            <span class="text-primary font-display text-xl">{idx + 1}.</span>
            {instruction.name}
          </h4>
          {instruction.text != null && (
            <p class="text-white/80 text-sm leading-relaxed">{instruction.text}</p>
          )}
          {instruction.itemListElement != null &&
            instruction.itemListElement.map((element) => {
              switch (element["@type"]) {
                case "HowToDirection":
                  return (
                    <p class="text-white/80 text-sm leading-relaxed">
                      {element.text}
                    </p>
                  );
                case "HowToTip":
                  return (
                    <div class="flex flex-col gap-2 p-4 bg-surface-3 rounded-lg border border-white/10">
                      <div class="flex items-center gap-2 text-primary font-semibold text-sm">
                        <LightBulb />
                        <span>Tip</span>
                      </div>
                      <p class="text-white/80 text-sm leading-relaxed">
                        {element.text}
                      </p>
                    </div>
                  );
                default:
                  throw new Error(
                    `itemListElement["@type"] switch has an illegal value: ${element["@type"]}`,
                  );
              }
            })}
        </li>
      ))
    }
  </ol>
</div>
