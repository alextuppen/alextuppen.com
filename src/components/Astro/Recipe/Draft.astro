---
import { ExclamationCircle } from "../../../svg";

interface Props {
  creativeWorkStatus: string;
}

const { creativeWorkStatus } = Astro.props;
---

{
  creativeWorkStatus === "draft" && (
    <div class="self-start inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 border border-primary/30 rounded-full text-xs text-primary font-medium">
      <ExclamationCircle className="w-3.5 h-3.5 shrink-0" />
      Draft — work in progress
    </div>
  )
}
