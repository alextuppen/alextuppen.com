---
---

<canvas id="hero-background-canvas" class="absolute inset-0 w-full h-full"></canvas>

<script>
  function debounce<T extends (...args: unknown[]) => void>(fn: T, delay: number): T {
    let timeout: ReturnType<typeof setTimeout>;
    return ((...args: unknown[]) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => fn(...args), delay);
    }) as T;
  }

  const canvas = document.getElementById("hero-background-canvas");
  if (!(canvas instanceof HTMLCanvasElement)) {
    throw new Error("Canvas not found");
  }

  const worker = new Worker(new URL("./HeroBackground.worker.ts", import.meta.url), { type: "module" });

  function getContentBounds() {
    const heroContent = document.getElementById("hero-content");
    if (heroContent) {
      const rect = heroContent.getBoundingClientRect();
      return { contentLeft: rect.left, contentRight: rect.right };
    }
    return { contentLeft: 0, contentRight: 0 };
  }

  const offscreen = canvas.transferControlToOffscreen();
  const { contentLeft, contentRight } = getContentBounds();

  worker.postMessage(
    {
      type: "init",
      canvas: offscreen,
      width: canvas.offsetWidth,
      height: canvas.offsetHeight,
      contentLeft,
      contentRight,
      rootFontSize: parseFloat(getComputedStyle(document.documentElement).fontSize),
    },
    [offscreen],
  );

  window.addEventListener("resize", debounce(() => {
    const { contentLeft, contentRight } = getContentBounds();
    worker.postMessage({
      type: "resize",
      width: canvas.offsetWidth,
      height: canvas.offsetHeight,
      contentLeft,
      contentRight,
    });
  }, 150));

  document.addEventListener("visibilitychange", () => {
    worker.postMessage({ type: document.hidden ? "visibilityPause" : "visibilityResume" });
  });

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      worker.postMessage({ type: entry.isIntersecting ? "intersectionResume" : "intersectionPause" });
    }
  });
  observer.observe(canvas);
</script>
