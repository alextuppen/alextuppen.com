---
import { Root } from "../layouts";
import { Education, Job } from "../components";
import { SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";

const experiences = await getCollection("experiences");
const sortedExperiences = experiences.sort((a, b) =>
  a.data.details.startDate < b.data.details.startDate ? 1 : -1,
);

const education = await getCollection("education");
const sortedEducation = education.sort((a, b) =>
  a.data.details.startDate < b.data.details.startDate ? 1 : -1,
);
---

<Root title="Experience" description={SITE_DESCRIPTION}>
  <div class="w-full max-w-4xl mx-auto px-4">
    <section class="py-12 flex flex-col gap-8">
      <h1 class="font-display font-medium text-3xl text-white lg:pl-[3.5rem]">
        Experience
      </h1>
      <div class="grid grid-cols-1 lg:grid-cols-[2rem_1fr] gap-x-6">
        {
          sortedExperiences.map(({ data }, i) => (
            <>
              <div class="hidden lg:flex flex-col items-center pt-7">
                <div
                  class={`w-3 h-3 rounded-full shrink-0 ${i === 0 ? "bg-primary border-2 border-primary" : "bg-surface-4 border-2 border-white/30"}`}
                />
                {i < sortedExperiences.length - 1 && (
                  <div class="w-px bg-white/10 flex-1 mt-7" />
                )}
              </div>
              <div class={i < sortedExperiences.length - 1 ? "pb-8" : ""}>
                <Job data={data} />
              </div>
            </>
          ))
        }
      </div>
    </section>

    <hr class="border-white/10" />

    <section class="py-12 flex flex-col gap-8">
      <h2 class="font-display font-medium text-3xl text-white lg:pl-[3.5rem]">
        Education
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-[2rem_1fr] gap-x-6">
        {
          sortedEducation.map(({ data }, i) => (
            <>
              <div class="hidden lg:flex flex-col items-center pt-7">
                <div class="w-3 h-3 rounded-full bg-surface-4 border-2 border-white/30 shrink-0" />
                {i < sortedEducation.length - 1 && (
                  <div class="w-px bg-white/10 flex-1 mt-7" />
                )}
              </div>
              <div class={i < sortedEducation.length - 1 ? "pb-8" : ""}>
                <Education data={data} />
              </div>
            </>
          ))
        }
      </div>
    </section>
  </div>
</Root>
