---
import { Root } from "../layouts";
import { SITE_DESCRIPTION } from "../consts";
---

<Root title="404" description={SITE_DESCRIPTION}>
  <div class="flex flex-col md:flex-row items-center justify-center gap-8 min-h-[60vh] px-4">
    <img
      width="160"
      height="240"
      src="/logo/white.svg"
      alt="Alex Tuppen logo"
      class="w-32 sm:w-40 lg:w-52 xl:w-64 opacity-80"
    />
    <div class="flex flex-col items-center md:items-start text-center md:text-left">
      <h1 class="font-display font-medium leading-none text-8xl sm:text-9xl lg:text-[10rem] xl:text-[12rem] text-white">
        404
      </h1>
      <h2 class="text-2xl sm:text-3xl text-white/60 font-normal">
        Page not found
      </h2>
    </div>
  </div>
</Root>
