---
import { Root } from "../../layouts";
import { SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import { BlogRecipeList, SearchInput } from "../../components";
const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const transformedPosts = sortedPosts.map(
  (
    { id, data: { heroImage, heroImageText, title, description, pubDate } },
    index,
  ) => ({
    href: `/blog/${id}`,
    title,
    src: heroImage,
    alt: heroImageText,
    date: pubDate,
    description,
    isFeatured: index === 0,
  }),
);
---

<Root title="Alex Tuppen | Blog" description={SITE_DESCRIPTION}>
  <div class="w-full max-w-4xl mx-auto px-4">
    <section class="py-12 flex flex-col gap-6">
      <div class="flex items-start gap-8">
        <div class="flex flex-col gap-4 min-w-0" style="max-width: 65ch">
          <h1 class="font-display font-medium text-3xl text-white">Blog</h1>
          <p class="text-white/70 leading-relaxed">
            I am trying to improve my technical writing and document the most
            interesting projects I have worked on. Posts cover topics across the
            full stack — architecture decisions, patterns I've found useful, and
            the occasional deep dive into something that took longer to figure
            out than it should have. If you have any feedback I'd love to hear
            it.
          </p>
          <SearchInput
            id="blog-recipe-search"
            placeholder={`Search ${transformedPosts.length} ${transformedPosts.length === 1 ? "post" : "posts"}...`}
          />
        </div>
        <div
          class="flex-1 self-stretch flex items-center justify-center hidden md:flex"
        >
          <img
            src="/logo/white.svg"
            alt="Alex Tuppen logo"
            class="w-20 opacity-20"
          />
        </div>
      </div>
      <BlogRecipeList list={transformedPosts} />
    </section>
  </div>
</Root>
